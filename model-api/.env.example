# SkinX Model API - Environment Configuration

# Model Paths (defaults for Docker /models mount point)
MODEL_DIR=/models
CLASS_CSV_PATH=/models/training_base_10k.csv
EFFICIENTNET_MODEL_PATH=/models/incremental_b5.pt
MEDSAM_MODEL_PATH=/models/medsam.pth
MOBILENET_MODEL_PATH=/models/mobilenet_v3_small-047dcff4.pth

# LLM API Configuration
# Set to "openrouter" to enable AI-generated reports, or "none" for fallback
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# API Server Configuration
PORT=8080
HOST=0.0.0.0

# Debug Mode - Only enable in development/staging, NEVER in production
# When false, /debug/* endpoints return 404
DEBUG=false
